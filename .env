# Configuration
# Step 1:
# Go to https://build.nvidia.com/
# Login/Create account

# Step 2:
# Open API Keys page:
# https://build.nvidia.com/settings/api-keys

# Step 3:
# Click "Generate API Key"

# Step 4:
# Copy generated key and paste below

NVIDIA_API_KEY=your_nvidia_api_key_here

# NVIDIA API Base URL
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# CORS Configuration - Frontend URLs allowed to access this backend
# Development: localhost:5173 (Vite), localhost:3000 (Next.js)
# Production: Vercel frontend deployment
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://quest-ide-frontend.vercel.app

# Recommended coding model
NVIDIA_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Model settings
NVIDIA_TEMPERATURE=0
NVIDIA_TOP_P=1
NVIDIA_MAX_TOKENS=2048

# Request timeout
LLM_TIMEOUT_SECONDS=30

PISTON_URL=http://16.112.68.119:2000
